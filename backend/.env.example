# Base de données
DATABASE_URL=sqlite:///./garage.db

# Gmail SMTP — Pour envoyer les emails de bienvenue
# IMPORTANT : Pour Gmail, utiliser un "Mot de passe d'application" :
#   1. Aller à https://myaccount.google.com/apppasswords
#   2. Générer un mot de passe pour "Autre (Nom personnalisé)" -> "Gestion Garage"
#   3. Copier le mot de passe généré ci-dessous
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# URL du frontend (pour les liens dans les emails)
FRONTEND_URL=http://localhost:5173
